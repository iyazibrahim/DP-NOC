# Site box Alloy environment variables (site-1)
#
# Put these in the site box before starting Alloy.
# The wallboard + API use the SITE_NAME as the site id label.

CENTRAL_REMOTE_WRITE_URL=http://<VPS_PUBLIC_IP>:9090/api/v1/write
SITE_NAME=site-1

PING_TARGET_1=1.1.1.1
PING_TARGET_2=203.0.113.10

SNMP_TARGET_1_IP=192.168.10.1

